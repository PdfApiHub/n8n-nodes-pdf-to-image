{
	"name": "n8n-nodes-pdf-to-image",
	"version": "1.0.0",
	"description": "Render PDF pages as PNG, JPG, or WebP images using PDF API Hub",
	"license": "MIT",
	"homepage": "https://pdfapihub.com",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"pdf-to-image",
		"pdf-to-png",
		"pdf-to-jpg",
		"pdfapihub"
	],
	"author": {
		"name": "Rishabh Dugar",
		"email": "rishabh.dugar.com@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/PdfApiHub/n8n-nodes-pdf-to-image.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/PdfapihubApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/PdfToImage/PdfToImage.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"@types/node": "^22.0.0",
		"eslint": "9.32.0",
		"typescript": "5.9.2",
		"release-it": "^19.0.4"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
